    "import yaml\n",
    "import argparse\n",
    "\n",
    "parser = argparse.ArgumentParser()\n",
    "parser.add_argument(\"--config\", required=True)\n",
    "\n",
    "args = parser.parse_args()\n",
    "\n",
    "with open(args.config) as f:\n",
    "    cfg = yaml.safe_load(f)\n",
    "\n",
    "print(cfg[\"dataset_id\"])"
